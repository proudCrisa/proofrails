#!/usr/bin/env bash
set -euo pipefail

# harness-lint — scan for forbidden terms and required files in the harness repo
#
# Scans: README*.md docs/ skill/ templates/ examples/ scripts/ .evidence/
# Forbidden terms: internal platform references that must not leak into the open-source repo.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

FORBIDDEN_TERMS=(
  "京东"
  "JD"
  "dongboot"
  "JoySpace"
  "shendeng"
  "sd.jd.com"
  "sso.jd.com"
  "OMC"
  "omc"
  "oh-my-claudecode"
)

REQUIRED_FILES=(
  "README.md"
  "docs/quickstart.md"
  "docs/concepts.md"
  "docs/recipes.md"
  "docs/troubleshooting.md"
  "docs/quickstart.zh-CN.md"
  "docs/concepts.zh-CN.md"
  "docs/recipes.zh-CN.md"
  "docs/troubleshooting.zh-CN.md"
  "docs/quickstart.fr.md"
  "docs/concepts.fr.md"
  "docs/recipes.fr.md"
  "docs/troubleshooting.fr.md"
  "skill/SKILL.md"
  "templates/AGENTS.md"
  "templates/CLAUDE.md"
  "templates/openspec-change.md"
  "templates/superpowers-execution.md"
  "scripts/bootstrap-harness"
  "scripts/harness-check"
  "scripts/harness-lint"
  ".evidence/implementation-notes.md"
)

SCAN_DIRS=(
  "README.md"
  "README.fr.md"
  "README.zh-CN.md"
  "docs"
  "skill"
  "templates"
  "examples"
  "scripts"
  ".evidence"
)

errors=0

# --- Check required files ---
echo "[harness-lint] Checking required files..."
for f in "${REQUIRED_FILES[@]}"; do
  if [ -f "$REPO_ROOT/$f" ]; then
    echo "[harness-lint]   $f: OK"
  else
    echo "[harness-lint]   $f: MISSING"
    errors=$((errors + 1))
  fi
done

# --- Scan for forbidden terms ---
echo "[harness-lint] Scanning for forbidden terms..."
while IFS= read -r -d '' file; do
  while IFS=: read -r linenum line; do
    for term in "${FORBIDDEN_TERMS[@]}"; do
      if echo "$line" | grep -qF "$term" 2>/dev/null; then
        rel="${file#$REPO_ROOT/}"
        echo "[harness-lint] FORBIDDEN: found \"$term\" in $rel:$linenum"
        errors=$((errors + 1))
      fi
    done
  done < <(cat -n "$file" 2>/dev/null || true)
done < <(for d in "${SCAN_DIRS[@]}"; do
  if [ -f "$REPO_ROOT/$d" ]; then
    printf '%s\0' "$REPO_ROOT/$d"
  elif [ -d "$REPO_ROOT/$d" ]; then
    find "$REPO_ROOT/$d" -type f -print0 2>/dev/null || true
  fi
done)

# --- Summary ---
echo ""
if [ "$errors" -eq 0 ]; then
  echo "[harness-lint] All checks passed."
else
  echo "[harness-lint] $errors issue(s) found."
  exit 1
fi
