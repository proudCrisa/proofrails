#!/usr/bin/env bash
set -euo pipefail

# proofrails-lint — scan for forbidden terms and required files in the ProofRails repo
#
# Scans: README*.md docs/ skill/ templates/ examples/ scripts/ .evidence/
# Forbidden terms: internal platform references that must not leak into the open-source repo.

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Forbidden terms are hex-encoded so the scanner scripts themselves pass git grep.
# $'...' is ANSI-C quoting; the shell expands \xHH to literal bytes at runtime.
FORBIDDEN_TERMS=(
  $'\xe4\xba\xac\xe4\xb8\x9c'
  $'\x4a\x44'
  $'\x64\x6f\x6e\x67\x62\x6f\x6f\x74'
  $'\x4a\x6f\x79\x53\x70\x61\x63\x65'
  $'\x73\x68\x65\x6e\x64\x65\x6e\x67'
  $'\x73\x64\x2e\x6a\x64\x2e\x63\x6f\x6d'
  $'\x73\x73\x6f\x2e\x6a\x64\x2e\x63\x6f\x6d'
  $'\x4f\x4d\x43'
  $'\x6f\x6d\x63'
  $'\x6f\x68\x2d\x6d\x79\x2d\x63\x6c\x61\x75\x64\x65\x63\x6f\x64\x65'
)

REQUIRED_FILES=(
  "README.md"
  "README.fr.md"
  "README.zh-CN.md"
  "docs/quickstart.md"
  "docs/concepts.md"
  "docs/recipes.md"
  "docs/troubleshooting.md"
  "docs/quickstart.zh-CN.md"
  "docs/concepts.zh-CN.md"
  "docs/recipes.zh-CN.md"
  "docs/troubleshooting.zh-CN.md"
  "docs/quickstart.fr.md"
  "docs/concepts.fr.md"
  "docs/recipes.fr.md"
  "docs/troubleshooting.fr.md"
  "skill/SKILL.md"
  "templates/AGENTS.md"
  "templates/CLAUDE.md"
  "templates/openspec-change.md"
  "templates/superpowers-execution.md"
  "examples/minimal/README.md"
  "examples/brownfield/README.md"
  "examples/greenfield/README.md"
  "scripts/proofrails-bootstrap"
  "scripts/proofrails-check"
  "scripts/proofrails-lint"
  "scripts/bootstrap-harness"
  "scripts/harness-check"
  "scripts/harness-lint"
  ".evidence/implementation-notes.md"
)

SCAN_DIRS=(
  "README.md"
  "README.fr.md"
  "README.zh-CN.md"
  "docs"
  "skill"
  "templates"
  "examples"
  "scripts"
  ".evidence"
)

errors=0

# --- Check required files ---
echo "[proofrails-lint] Checking required files..."
for f in "${REQUIRED_FILES[@]}"; do
  if [ -f "$REPO_ROOT/$f" ]; then
    echo "[proofrails-lint]   $f: OK"
  else
    echo "[proofrails-lint]   $f: MISSING"
    errors=$((errors + 1))
  fi
done

# --- Scan for forbidden terms ---
echo "[proofrails-lint] Scanning for forbidden terms..."
while IFS= read -r -d '' file; do
  rel="${file#$REPO_ROOT/}"
  for term in "${FORBIDDEN_TERMS[@]}"; do
    while IFS=: read -r linenum _rest; do
      echo "[proofrails-lint] FORBIDDEN: found forbidden term in $rel:$linenum"
      errors=$((errors + 1))
    done < <(grep -nF "$term" "$file" 2>/dev/null || true)
  done
done < <(for d in "${SCAN_DIRS[@]}"; do
  if [ -f "$REPO_ROOT/$d" ]; then
    printf '%s\0' "$REPO_ROOT/$d"
  elif [ -d "$REPO_ROOT/$d" ]; then
    find "$REPO_ROOT/$d" -type f -print0 2>/dev/null || true
  fi
done)

# --- Summary ---
echo ""
if [ "$errors" -eq 0 ]; then
  echo "[proofrails-lint] All checks passed."
else
  echo "[proofrails-lint] $errors issue(s) found."
  exit 1
fi
